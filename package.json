{
  "name": "pixelops",
  "version": "0.1.0",
  "description": "Pixel art command center for monitoring Claude Code sessions",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build && electron-builder",
    "vite:dev": "vite",
    "vite:build": "vite build"
  },
  "keywords": [
    "claude",
    "pixel-art",
    "electron",
    "monitoring"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@pixi/react": "^8.0.5",
    "chokidar": "^5.0.0",
    "pixi.js": "^8.17.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zustand": "^5.0.12"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "vite": "^5.4.21",
    "wait-on": "^9.0.4"
  }
}
